      },
      "id": 5,
      "title": "Database Connection Health",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "up{job=\"fastapi\"}",
          "legendFormat": "Status (1=Up, 0=Down)",
          "range": true,
          "refId": "A"
        }
